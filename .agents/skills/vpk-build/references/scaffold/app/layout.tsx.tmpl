import type { Metadata } from "next";

// Order matters: ADS token reset first, then VPK's semantic Tailwind theme.
// Both are required for the semantic classes (bg-surface-raised, text-text-subtle,
// duration-normal, etc.) to resolve correctly at build time.
import "@atlaskit/tokens/css-reset.css";
import "./tailwind-theme.css";

import { ThemeWrapper } from "@/components/utils/theme-wrapper";

export const metadata: Metadata = {
	title: "{{TARGET_NAME}}",
	description: "Extracted from VPK-Rovo /{{ROUTE_NAME}}",
};

export default function RootLayout({
	children,
}: Readonly<{ children: React.ReactNode }>) {
	return (
		<html lang="en" suppressHydrationWarning>
			<body className="min-h-svh bg-bg-neutral text-text antialiased">
				<ThemeWrapper>{children}</ThemeWrapper>
			</body>
		</html>
	);
}
