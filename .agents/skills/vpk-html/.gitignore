# vpk-html local artifacts
# Generated outputs are committed (gallery thumbnails, demo PNGs, ported diagrams)
# so the gallery renders without a build step. Anything below is local-only.

.DS_Store
*.log

# Local payload scratch space (not part of the example fixture set)
/local/
/.tmp/

# Routine renders should live under docs/html/<slug>.html at the repo root, but
# if anyone redirects local experiments inside this skill, keep them untracked.
/output-scratch/
