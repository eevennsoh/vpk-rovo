# Chat routing
# - Standard /api/chat-sdk turns require RovoDev Serve.
# - AI Gateway credentials below power gateway-backed routes such as image,
#   sound, suggestions, plan/title metadata, and Realtime voice.
#
# Preferred local startup:
# - Run `pnpm run rovodev` to start RovoDev Serve + backend + frontend.
# - Or start RovoDev separately, then run `pnpm run dev`.

# RovoDev Serve pool size (number of concurrent RovoDev instances for agents team, default: 1)
# ROVODEV_POOL_SIZE=1

# Optional explicit RovoDev port override (normally auto-managed)
# ROVODEV_PORT=8000

# RovoDev Session Token
# Authenticates the backend with RovoDev Serve (required).
# This is a one-time setup — the token does not expire or rotate.
#
# How to get it:
#   1. Run: acli rovodev   (or: pnpm run rovodev)
#   2. On first launch, RovoDev Serve prints a session token to the terminal.
#   3. Copy that token and paste it here.
#   4. Restart the dev stack so the backend picks up the token.
#
# The backend sends this as "Authorization: Bearer <token>" to RovoDev Serve,
# and the supervisor passes it to serve instances as ROVODEV_SERVE_SESSION_TOKEN.
ROVODEV_SESSION_TOKEN=<paste-token-from-rovodev-serve-output>

# Billing URL for rovodev serve
ROVODEV_BILLING_URL=https://product-fabric.atlassian.net

# Atlassian site URL for Confluence/Jira context in prompts
ROVODEV_SITE_URL=https://hello.atlassian.net
NEXT_PUBLIC_ROVODEV_SITE_URL=https://hello.atlassian.net

# Browser automation defaults to live Canary when a local Canary executable is available.
# Set this explicitly if you want to force a mode instead of using the auto-default.
# ROVO_BROWSER_MODE=live-canary

# Optional run-summary sharing integrations
# CONFLUENCE_BASE_URL=https://venn-test.atlassian.net/wiki
# CONFLUENCE_USER_EMAIL=<your-email@company.com>
# CONFLUENCE_API_TOKEN=<confluence-api-token>
# CONFLUENCE_DEFAULT_SPACE_KEY=<SPACEKEY>
# CONFLUENCE_PARENT_PAGE_ID=<optional-parent-page-id>
# SLACK_BOT_TOKEN=<xoxb-...>
# SLACK_DM_USER_ID=<U01234567>

# Symphony / Linear integration
# Required when running upstream Symphony (`pnpm run symphony`).
# WORKFLOW.md references LINEAR_API_KEY and SYMPHONY_LINEAR_PROJECT_SLUG.
# Keep real Linear API keys in ignored `.env.local` or the shell only.
# This tracked example file must contain placeholders only.
#
# How to get them:
#   - LINEAR_API_KEY: linear.app -> Settings -> API -> "Personal API keys" -> Create key
#   - SYMPHONY_LINEAR_PROJECT_SLUG: copy the slug from the Linear project URL
# LINEAR_API_KEY=<linear-personal-api-key>
# SYMPHONY_LINEAR_PROJECT_SLUG=<your-linear-project-slug>
# Optional: limit polling to the authenticated Linear user or a specific assignee.
# LINEAR_ASSIGNEE=me
# Optional: override the repo cloned into each issue workspace.
# SYMPHONY_SOURCE_REPO_URL=git@github.com:eevennsoh/VPK-rovo.git
# Optional: override where upstream Symphony creates issue workspaces.
# SYMPHONY_WORKSPACE_ROOT=/tmp/symphony-workspaces
# Optional: copy a local env file into each issue workspace for app bootability.
# SYMPHONY_ENV_LOCAL_SOURCE=/absolute/path/to/VPK-rovo/.env.local
# Optional: override the cached local clone of openai/symphony.
# SYMPHONY_DIR=.tmp/symphony/openai-symphony
# Optional: override the rendered workflow and log directory.
# SYMPHONY_RUNTIME_DIR=.tmp/symphony/runtime

# Required for AI Gateway-backed routes
# AI_GATEWAY_URL=https://<your-ai-gateway-endpoint>
# AI_GATEWAY_URL_GOOGLE=https://<your-ai-gateway-google-endpoint>
# AI_GATEWAY_USE_CASE_ID=<your-use-case-id>
# AI_GATEWAY_CLOUD_ID=<your-cloud-id>
# AI_GATEWAY_USER_ID=<your-user-id>
# ASAP_PRIVATE_KEY="<your-private-key-with-\\n>"
# ASAP_KID=<your-asap-kid>
# ASAP_ISSUER=<your-asap-issuer>

# OpenAI model ID (used when AI_GATEWAY_URL points to an OpenAI endpoint)
# OPENAI_MODEL=gpt-5.5-2026-04-23
# Google model IDs (used when model is not specified in the request body)
# GOOGLE_IMAGE_MODEL=gemini-3-pro-image-preview
# GOOGLE_TTS_MODEL=tts-latest
# GOOGLE_STT_MODEL=gemini-3-flash-preview

# Speech-to-text preset used by live voice mode and /api/speech-transcription
# Switch only this line to swap STT backends/models:
# STT_PRESET=qwen3-asr
#
# Supported presets:
# - whisper-tiny
# - whisper-large-v3
# - google
# - qwen3-0.6b
# - qwen3-asr
#
# STT_PRESET_WHISPER_TINY_PROVIDER=local-whisper
# STT_PRESET_WHISPER_TINY_MODEL=tiny
#
# STT_PRESET_WHISPER_LARGE_V3_PROVIDER=local-whisper
# STT_PRESET_WHISPER_LARGE_V3_MODEL=large-v3
#
# STT_PRESET_GOOGLE_PROVIDER=google
# Uses GOOGLE_STT_MODEL as the selected Google STT model
#
# STT_PRESET_QWEN3_0_6B_PROVIDER=openai-compatible
# STT_PRESET_QWEN3_0_6B_MODEL=qwen3-0.6b
#
# STT_PRESET_QWEN3_ASR_PROVIDER=openai-compatible
# STT_PRESET_QWEN3_ASR_MODEL=qwen3-asr
#
# LOCAL_WHISPER_MODEL=tiny
# LOCAL_WHISPER_BIN=whisper
#
# Optional fallback model for openai-compatible audio transcription endpoints
# OPENAI_COMPATIBLE_STT_MODEL=qwen3-asr
#
# Defaults to http://localhost:8801/v1 for qwen3-0.6b and qwen3-asr presets
# Uncomment to override
# OPENAI_COMPATIBLE_STT_BASE_URL=http://localhost:8801/v1
# Optional auth for the openai-compatible STT endpoint
# OPENAI_COMPATIBLE_STT_API_KEY=

# OpenAI Realtime API (live voice conversation mode via AI Gateway)
# Set OPENAI_REALTIME_API_KEY only if bypassing AI Gateway with a direct OpenAI key.
# OPENAI_REALTIME_API_KEY=
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_WS_URL=wss://ai-gateway.us-east-1.staging.atl-paas.net/v1/openai/v1/realtime
OPENAI_REALTIME_VOICE=alloy

# Optional configuration
# Frontend API URL (for production builds)
# NEXT_PUBLIC_API_URL=https://your-service-name.us-west-2.platdev.atl-paas.net

PERSONAL_GRAPH_LIBRARIAN_MODEL=
PERSONAL_GRAPH_SUMMARIZE_MODEL=auto
PERSONAL_GRAPH_SUMMARIZE_TIMEOUT_MS=180000
# Optional; defaults to personal-graph.
# PERSONAL_GRAPH_QMD_COLLECTION=personal-graph
PERSONAL_GRAPH_QMD_MCP_URL=

# Backend port (default: 8080)
# PORT=8080

# Backend URL for frontend (default: http://localhost:8080)
# BACKEND_URL=http://localhost:8080

# Debug mode (set to true for verbose logging)
# DEBUG=true
