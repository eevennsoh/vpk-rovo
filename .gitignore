.gsd/activity/
.gsd/forensics/
.gsd/runtime/
.gsd/worktrees/
.gsd/parallel/
.gsd/auto.lock
.gsd/metrics.json
.gsd/completed-units.json
.gsd/STATE.md
.gsd/gsd.db
.gsd/DISCUSSION-MANIFEST.json
.gsd/milestones/**/*-CONTINUE.md
.gsd/milestones/**/continue.md
Thumbs.db
*.swp
*.swo
*~
