# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/backend/node_modules
/.venv
.pnpm-store/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# browser automation artifacts
/screenshots
/public/screenshots/
.playwright-cli/
.bg-shell/
.tmp-agent-browser-home/
.tmp-*.cjs
.tmp-*.mjs
test-results/

# output
/output

# root-level screenshots/images (keep nested assets tracked)
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
/*.bmp
/*.tif
/*.tiff
/*.avif
/*.heic
/*.heif

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
tmux-*.log

# env files (can opt-in for committing if needed)
.env*
!*.example

# ASAP config (contains private keys - never commit)
.asap-config

# Deploy configuration (contains Docker credentials)
.deploy.local

# cmux
cmux.json

# Dev process management
.dev-pids
.dev-backend-port
.dev-frontend-port
.dev-rovodev-port
.dev-rovodev-ports
.dev-rovodev-token
.api-routes-backup
.rovodev/config.generated.yml
.rovodev/mcp.generated.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local plugin settings
*.local.md
*.local.json

# Additional key/credential patterns
*.key
*.p8
*.pkcs8
*.jks
*.keystore
credentials*
secrets*
.envrc
.netrc
.npmrc
.pypirc
*service-account*.json

# Task management plans (project-scoped, source-controlled so Symphony
# workers can read them in cloned workspaces)
/backend/data/

# IDE settings
.idea/
.vscode/settings.json
.vscode/*.log
.playwright-mcp/

