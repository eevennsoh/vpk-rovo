{
	"browser": {
		"browserName": "chromium",
		"isolated": true,
		"contextOptions": {
			"viewport": {
				"width": 1440,
				"height": 900
			}
		}
	},
	"outputDir": "output/playwright",
	"outputMode": "file",
	"console": {
		"level": "warning"
	},
	"timeouts": {
		"action": 8000,
		"navigation": 60000
	},
	"codegen": "none"
}
