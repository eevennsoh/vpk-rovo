{
	"mcpServers": {
		"forge-knowledge": {
			"url": "https://mcp.atlassian.com/v1/forge/mcp",
			"transport": "http"
		},
		"ads-mcp": {
			"url": "https://mcp.atlassian.com/v1/ads/public/mcp"
		},
		"web-search": {
			"command": "npx",
			"args": [
				"open-websearch@latest"
			],
			"env": {
				"MODE": "stdio",
				"DEFAULT_SEARCH_ENGINE": "google",
				"ALLOWED_SEARCH_ENGINES": "google,duckduckgo,bing"
			}
		},
		"browser-workspace": {
			"args": [
				"/Users/esoh/Documents/Labs/agent-browser/scripts/browser-workspace-mcp.js"
			],
			"command": "node",
			"env": {
				"REPO_ROOT": "/Users/esoh/Documents/Labs/agent-browser"
			},
			"type": "stdio"
		},
		"hermes-tools": {
			"type": "stdio",
			"command": "/Users/esoh/Documents/Labs/hermes/hermes-agent/.venv/bin/python",
			"args": [
				"/Users/esoh/Documents/Labs/VPK-rovo/scripts/hermes_tools_mcp.py"
			],
			"env": {
				"PYTHONUNBUFFERED": "1",
				"HERMES_TOOLS_SERVER_NAME": "hermes-tools",
				"HERMES_AGENT_PATH": "/Users/esoh/Documents/Labs/hermes/hermes-agent"
			}
		},
		"qmd": {
			"args": [
				"exec",
				"qmd",
				"mcp"
			],
			"command": "pnpm",
			"env": {
				"INDEX_PATH": "/Users/esoh/Documents/Labs/agent-browser/.cache/qmd/wiki.sqlite"
			},
			"type": "stdio"
		}
	},
	"inputs": []
}
