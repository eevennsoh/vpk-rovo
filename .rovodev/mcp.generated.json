{
	"mcpServers": {
		"forge-knowledge": {
			"url": "https://mcp.atlassian.com/v1/forge/mcp",
			"transport": "http"
		},
		"ads-mcp": {
			"url": "https://mcp.atlassian.com/v1/ads/public/mcp"
		},
		"web-search": {
			"command": "npx",
			"args": [
				"open-websearch@latest"
			],
			"env": {
				"MODE": "stdio",
				"DEFAULT_SEARCH_ENGINE": "google",
				"ALLOWED_SEARCH_ENGINES": "google,duckduckgo,bing"
			}
		},
		"browser-workspace": {
			"args": [
				"/Users/esoh/.codex/worktrees/8162/VPK-rovo/scripts/browser-workspace-mcp.js"
			],
			"command": "node",
			"env": {
				"REPO_ROOT": "/Users/esoh/.codex/worktrees/8162/VPK-rovo"
			},
			"type": "stdio"
		},
		"wiki-capture": {
			"args": [
				"/Users/esoh/.codex/worktrees/8162/VPK-rovo/scripts/wiki-capture-mcp.js"
			],
			"command": "node",
			"env": {
				"REPO_ROOT": "/Users/esoh/.codex/worktrees/8162/VPK-rovo"
			},
			"type": "stdio"
		},
		"qmd": {
			"args": [
				"exec",
				"qmd",
				"mcp"
			],
			"command": "pnpm",
			"env": {
				"INDEX_PATH": "/Users/esoh/.codex/worktrees/8162/VPK-rovo/.cache/qmd/wiki.sqlite"
			},
			"type": "stdio"
		}
	},
	"inputs": []
}
