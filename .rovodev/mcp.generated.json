{
	"mcpServers": {
		"figma-desktop": {
			"url": "http://127.0.0.1:3845/mcp",
			"transport": "http"
		},
		"forge-knowledge": {
			"url": "https://mcp.atlassian.com/v1/forge/mcp",
			"transport": "http"
		},
		"ads-mcp": {
			"url": "https://mcp.atlassian.com/v1/ads/public/mcp"
		},
		"web-search": {
			"command": "npx",
			"args": [
				"open-websearch@latest"
			],
			"env": {
				"MODE": "stdio",
				"DEFAULT_SEARCH_ENGINE": "google",
				"ALLOWED_SEARCH_ENGINES": "google,duckduckgo,bing"
			}
		},
		"browser-workspace": {
			"args": [
				"/Users/esoh/Documents/Labs/vpk-rovo/scripts/browser-workspace-mcp.js"
			],
			"command": "node",
			"env": {
				"REPO_ROOT": "/Users/esoh/Documents/Labs/vpk-rovo"
			},
			"type": "stdio"
		},
		"wiki-capture": {
			"args": [
				"/Users/esoh/Documents/Labs/vpk-rovo/scripts/wiki-capture-mcp.js"
			],
			"command": "node",
			"env": {
				"REPO_ROOT": "/Users/esoh/Documents/Labs/vpk-rovo"
			},
			"type": "stdio"
		},
		"Figma MCP": {
			"command": "npx",
			"args": [
				"-y",
				"figma-developer-mcp",
				"--figma-api-key=YOUR_FIGMA_API_KEY",
				"--stdio"
			],
			"disabled": true
		},
		"ads": {
			"command": "npx",
			"args": [
				"-y",
				"@atlaskit/ads-mcp"
			],
			"disabled": false
		},
		"Framelink Figma MCP": {
			"command": "npx",
			"args": [
				"-y",
				"figma-developer-mcp",
				"--figma-api-key=${FIGMA_ACCESS_TOKEN}",
				"--stdio"
			],
			"disabled": false
		}
	},
	"inputs": []
}
